<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ui.main.comprador.CompradorFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RYBAK"
            android:textSize="38sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Panel de Comprador"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#444444"
            android:layout_gravity="center"
            android:layout_marginTop="8dp" />

        <!-- INICIO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="85dp"
            android:background="@drawable/style_edit_text"
            android:orientation="vertical"
            android:padding="15dp"
            android:layout_marginTop="25dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inicio"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pantalla principal del usuario"
                android:textSize="14sp"
                android:textColor="#666666" />
        </LinearLayout>

        <!-- CATÁLOGO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="85dp"
            android:background="@drawable/style_edit_text"
            android:orientation="vertical"
            android:padding="15dp"
            android:layout_marginTop="15dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Catálogo de Productos"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/explorar_productos_disponibles"
                android:textSize="14sp"
                android:textColor="#666666" />
        </LinearLayout>

        <!-- DETALLE PRODUCTO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="85dp"
            android:background="@drawable/style_edit_text"
            android:orientation="vertical"
            android:padding="15dp"
            android:layout_marginTop="15dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/detalle_de_producto"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/informaci_n_completa_del_producto"
                android:textSize="14sp"
                android:textColor="#666666" />
        </LinearLayout>

        <!-- CARRITO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="85dp"
            android:background="@drawable/style_edit_text"
            android:orientation="vertical"
            android:padding="15dp"
            android:layout_marginTop="15dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/carrito_de_compras"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/productos_seleccionados"
                android:textSize="14sp"
                android:textColor="#666666" />
        </LinearLayout>

        <!-- PAGOS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="85dp"
            android:background="@drawable/style_edit_text"
            android:orientation="vertical"
            android:padding="15dp"
            android:layout_marginTop="15dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pasarela_de_pagos"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/procesar_pagos_de_forma_segura"
                android:textSize="14sp"
                android:textColor="#666666" />
        </LinearLayout>

        <!-- PERFIL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="85dp"
            android:background="@drawable/style_edit_text"
            android:orientation="vertical"
            android:padding="15dp"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="30dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/perfil_de_usuario"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/configuraci_n_de_cuenta"
                android:textSize="14sp"
                android:textColor="#666666" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>